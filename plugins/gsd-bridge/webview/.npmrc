# @json-render/shadcn@0.18.0 declares a peer on tailwindcss@^4 but UI-SPEC
# locks Tailwind v3 (v4 changes config model — OUT OF SCOPE per
# RENDERER-CONTRACT §6 + UI-SPEC §Tailwind Theme Configuration).
# Shadcn templates only emit class strings — no runtime Tailwind import —
# so the v4 peer is nominal. Legacy-peer-deps is the canonical npm resolution
# for prescriptive-but-non-runtime peer mismatches.
legacy-peer-deps=true
